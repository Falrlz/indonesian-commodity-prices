# =========================================================
# ENVIRONMENT CONFIGURATION
# =========================================================
# Template konfigurasi untuk ETL & scraping harga komoditas
# Copy file ini ke .env lalu sesuaikan nilainya
# =========================================================


# =========================================================
# AUTHENTICATION
# =========================================================
# Cookie digunakan untuk autentikasi ke endpoint target scraping.
# Biasanya didapat dari browser (DevTools → Network → Request Headers).
#
# NOTE:
# - Cookie memiliki masa berlaku (expired), perlu diperbarui secara berkala
# - Jika scraping gagal (403/401), cek validitas cookie
COOKIE=your_cookie_here


# =========================================================
# DATE RANGE CONFIGURATION
# =========================================================
# Rentang tanggal data yang akan diambil.
# Format wajib: YYYY-MM-DD
START_DATE=2026-01-01
END_DATE=2026-04-30


# =========================================================
# SCRAPING CONTROL
# =========================================================
# Delay antar request (dalam detik) untuk menghindari:
# - Rate limiting
# - IP blocking
# - Server overload
#
# REKOMENDASI:
# - 0.2 - 0.5 untuk scraping ringan
# - 1.0+ jika target sensitif terhadap traffic
REQUEST_DELAY=1.0


# =========================================================
# DEBUGGING & SAMPLING
# =========================================================
# Membatasi jumlah data yang diambil untuk keperluan testing.
#
# USE CASE:
# - Debug pipeline tanpa memproses seluruh dataset
# - Validasi struktur data sebelum full run
#
# SETTING:
# - NULL / hapus → ambil semua data
# - angka (misal 5) → batasi jumlah variasi
MAX_VARIANTS=


# =========================================================
# STORAGE CONFIGURATION
# =========================================================
# Path untuk penyimpanan hasil pipeline.
#
# STAGING_PATH:
# - Output sementara hasil cleaning/transformation
# - Format: CSV (intermediate layer)
#
# DB_PATH:
# - Database utama (DuckDB)
# - Digunakan untuk querying dan analytics
#
# BEST PRACTICE:
# - Pisahkan staging dan production layer
# - Gunakan struktur folder konsisten (data/staging, data/db)
STAGING_PATH=data/staging/harga_komoditas_clean.csv
DB_PATH=data/db/komoditas.duckdb